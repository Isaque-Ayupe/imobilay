# ============================================================
# IMOBILAY — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env — ele está no .gitignore.

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=seu-service-role-key-aqui

# ── Google Gemini (LLM — apenas ResponseVerbalizer) ─────────
GEMINI_API_KEY=sua-gemini-api-key-aqui

# ── Redis / Upstash (cache + circuit breaker state) ─────────
REDIS_URL=redis://localhost:6379
# Ou Upstash:
# REDIS_URL=rediss://default:token@endpoint.upstash.io:6379

# ── Configurações do Pipeline ────────────────────────────────
PIPELINE_MAX_RETRIES=3
PIPELINE_TIMEOUT_MS=8000
SCRAPER_TIMEOUT_S=5

# ── Frontend (Vite) ─────────────────────────────────────────
VITE_API_URL=http://localhost:8000
